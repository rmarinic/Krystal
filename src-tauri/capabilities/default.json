{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the Krystal main window: core IPC + native dialog + self-update.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
