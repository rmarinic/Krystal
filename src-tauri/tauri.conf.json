{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Krystal",
  "version": "0.6.0",
  "identifier": "com.krystal.claudecode",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Krystal · claude code",
        "width": 1280,
        "height": 860,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "Local Claude Code chat",
    "longDescription": "A local chat-app frontend for Claude Code — talk to Claude over your own documents, fully offline UI, native folder picker.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/rmarinic/Krystal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGQTY2N0Q4MjUzRDQ4OTUKUldTVlNEMGwyR2VtSDNYWUlTVHM4UkFkZVZGUnY3Y2Rkem1lYTdyZDJJckJDelZpTjZxczQ5dGkK"
    }
  }
}
